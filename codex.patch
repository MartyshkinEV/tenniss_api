 def expected_score(ra, rb):
     return 1.0 / (1.0 + 10 ** ((rb - ra) / 400.0))
 
 
 def update_elo(ra, rb, score_a, k=K_FACTOR):
     ea = expected_score(ra, rb)
     eb = expected_score(rb, ra)
     new_ra = ra + k * (score_a - ea)
     new_rb = rb + k * ((1.0 - score_a) - eb)
